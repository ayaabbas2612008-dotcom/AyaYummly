<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_beige">

    <LinearLayout
        android:id="@+id/headerComments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMMUNITY"
            android:textColor="@color/text_mid"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Comments"
            android:textColor="@color/brown_dark"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:layout_marginTop="4dp" />

        <View
            android:layout_width="45dp"
            android:layout_height="4dp"
            android:layout_marginTop="10dp"
            android:background="@color/brown_dark" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCommentsPage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerComments"
        android:layout_above="@+id/commentInputCard"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/commentInputCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="8dp"
        android:backgroundTint="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp">

            <EditText
                android:id="@+id/etCommentPage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Share your thoughts..."
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:minHeight="48dp"
                android:paddingHorizontal="12dp"
                android:textColor="@color/text_dark"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPostCommentPage"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="Send Comment"
                app:backgroundTint="@color/brown_dark"
                app:cornerRadius="24dp"
                app:icon="@android:drawable/ic_menu_send"
                app:iconTint="@color/white" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</RelativeLayout>
