<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_beige">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="26dp"
        android:gravity="top|center_horizontal">

        <!-- صورة البروفايل -->
        <ImageView
            android:id="@+id/ivProfileImage"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_user"
            android:layout_marginBottom="16dp"
            android:background="@drawable/circle_bg"
            android:padding="10dp" />

        <!-- العنوان -->
        <TextView
            android:id="@+id/tvProfileTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Profile"
            android:textSize="30sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="@color/brown_dark"
            android:layout_marginBottom="28dp" />

        <!-- بطاقة معلومات المستخدم -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@color/beige_card"
            android:elevation="6dp"
            android:layout_marginBottom="26dp"
            android:layout_marginHorizontal="6dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvUserEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="user@email.com"
                android:textSize="16sp"
                android:textColor="@color/text_mid"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvAccountCreated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Member since: 2024"
                android:textSize="14sp"
                android:textColor="@color/text_mid" />
        </LinearLayout>

        <!-- زر My Recipes -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMyRecipes"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="My Recipes"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/brown_dark"
            android:textColor="@color/bg_beige"
            app:cornerRadius="16dp"
            android:layout_marginBottom="14dp"
            app:icon="@drawable/ic_book"
            app:iconTint="@color/bg_beige"
            app:iconPadding="12dp"
            app:iconGravity="textStart" />

        <!-- زر Favorites -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFavorites"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Favorites"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/brown_dark"
            android:textColor="@color/bg_beige"
            app:cornerRadius="16dp"
            android:layout_marginBottom="14dp"
            app:icon="@drawable/ic_favorite"
            app:iconTint="@color/bg_beige"
            app:iconPadding="12dp"
            app:iconGravity="textStart" />

        <!-- زر Logout -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Logout"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/red"
            android:textColor="@android:color/white"
            app:cornerRadius="16dp"
            android:layout_marginTop="20dp"
            app:icon="@drawable/ic_logout"
            app:iconTint="@android:color/white"
            app:iconPadding="12dp"
            app:iconGravity="textStart" />

    </LinearLayout>

</ScrollView>
